# Caddyfile cho TEST tich hop (job stats-integration). MIRROR handler /stats cua
# Caddyfile prod nhung chay HTTP :80 (auto_https off -> khong xin ACME tren CI).
# Muc dich: kiem chung forward_auth -> reverse_proxy node-dedup hoat dong khi
# node-dedup la container RIENG (khong co tailscale sidecar trong stack test).
{
	auto_https off
	admin off
}

:80 {
	handle /stats* {
		forward_auth oauth2-proxy:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-Email X-Auth-Request-User
			@unauth status 401
			handle_response @unauth {
				redir * /oauth2/start?rd={http.request.uri}
			}
		}
		reverse_proxy node-dedup:8090
	}
}
