FROM golang:1.23-alpine AS builder
# Build derper tu source chinh thuc cua tailscale.
# Pin version de CI/deploy co the tao lai image giong nhau.
ARG TAILSCALE_VERSION=v1.80.0
RUN go install tailscale.com/cmd/derper@${TAILSCALE_VERSION}

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /go/bin/derper /usr/bin/derper
EXPOSE 443 80 3478/udp
ENTRYPOINT ["derper"]
