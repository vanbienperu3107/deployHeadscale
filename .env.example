# File .env (gitignored) chứa secret cho oauth2-proxy (SSO Google bảo vệ /admin).
#
# KHÔNG cần tạo .env bằng tay trên VPS: workflow Deploy tự ghi file này từ
# GitHub Secrets cùng tên (OAUTH2_PROXY_CLIENT_ID / _CLIENT_SECRET / _COOKIE_SECRET).
# File .env.example này chỉ để tham khảo các biến cần có.

# Từ Google Cloud Console → OAuth 2.0 Client ID (Web application)
OAUTH2_PROXY_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Chuỗi ngẫu nhiên 32 byte: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# Ghi chú: domain/IP của Headscale nằm trong config/config.yaml + Caddyfile (đã commit),
# email được phép đăng nhập nằm trong oauth2-proxy/emails.txt.
