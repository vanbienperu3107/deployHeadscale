# Copy file này thành .env rồi điền giá trị thật.
# LƯU Ý: Headscale đọc trực tiếp từ config/config.yaml và Caddyfile,
# nên bạn vẫn phải sửa placeholder trong 2 file đó. File .env này chỉ để
# ghi nhớ tập trung các giá trị cần thay.

# Domain control plane (Caddyfile + config.yaml: server_url)
HS_DOMAIN=hs.yourdomain.com

# Base domain cho MagicDNS (config.yaml: dns.base_domain)
HS_BASE_DOMAIN=tail.yourdomain.com

# IPv4 public của VPS (config.yaml: derp.server.ipv4)
HS_PUBLIC_IP=YOUR_SERVER_PUBLIC_IP

# Email cho Let's Encrypt (tùy chọn, Caddy tự xử lý nếu bỏ trống)
ACME_EMAIL=you@example.com
