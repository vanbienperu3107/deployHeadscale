# Reverse proxy + auto TLS (Let's Encrypt) cho Headscale.
{
	# Plugin replace-response: cho phep dung directive `replace` (chen nut Thong ke).
	order replace after encode
}

vpn2.hangocthanh.io.vn {
	# Log truy cap JSON ra stdout (docker logs caddy) — co status + loi upstream,
	# rat huu ich khi chan doan 502/loi proxy. Cookie/Authorization tu dong REDACTED.
	log {
		output stdout
		format json
	}

	# Các endpoint của oauth2-proxy (đăng nhập Google, callback...)
	handle /oauth2/* {
		reverse_proxy oauth2-proxy:4180 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Uri {uri}
		}
	}

	# Web UI /admin → Headplane. Headplane tự lo đăng nhập Google (OIDC) nên
	# KHÔNG cần forward_auth/oauth2-proxy ở đây nữa. Callback của Headplane là
	# /admin/oidc/callback (vẫn nằm trong /admin → headplane).
	handle /admin* {
		# Chen 2 nut co dinh vao goc phai duoi cua trang Headplane:
		#   "DERP Status" (link sang /derp-status) va "Thong ke" (link sang /stats).
		# Accept-Encoding identity de Headplane tra HTML khong nen -> replace khop.
		reverse_proxy headplane:3000 {
			header_up Accept-Encoding identity
		}
		replace `</body>` `<div style="position:fixed;z-index:99999;right:18px;bottom:18px;display:flex;gap:8px"><a href="/derp-status" target="_blank" title="DERP relay status" style="background:#7c3aed;color:#fff;padding:10px 16px;border-radius:10px;font:600 13px system-ui,Arial,sans-serif;text-decoration:none;box-shadow:0 4px 14px rgba(0,0,0,.45)">&#127760; DERP</a><a href="/stats" target="_blank" title="Xem thong ke latency/MAC" style="background:#2563eb;color:#fff;padding:10px 16px;border-radius:10px;font:600 13px system-ui,Arial,sans-serif;text-decoration:none;box-shadow:0 4px 14px rgba(0,0,0,.45)">&#128202; Th&#7889;ng k&#234;</a></div></body>`
	}

	# Captive-portal probe cua client (fork dung domain rieng thay tailscale.com)
	# -> tra 204 de client biet "khong co captive portal".
	handle /generate_204 {
		respond 204
	}

	# Trang thong ke (GUI) /stats - gated bang Google SSO (oauth2-proxy). Tro toi
	# node-dedup (container RIENG, on dinh tren compose network) - KHONG phu thuoc
	# tailscale sidecar nua (sidecar co the restart khi thieu authkey ma /stats van
	# chay). CHI GET (xem). Chua dang nhap -> redirect sang Google.
	handle /stats* {
		forward_auth oauth2-proxy:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-Email X-Auth-Request-User
			@unauth status 401
			handle_response @unauth {
				redir * /oauth2/start?rd={http.request.uri}
			}
		}
		reverse_proxy node-dedup:8090
	}

	# DERP status page (/derp-status) - gated bang Google SSO.
	# Du lieu tu node_latency DB qua node-dedup.
	# Doi URL tu /derp sang /derp-status de giai phong /derp cho relay thuc su.
	handle /derp-status* {
		forward_auth oauth2-proxy:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-Email X-Auth-Request-User
			@unauth status 401
			handle_response @unauth {
				redir * /oauth2/start?rd={http.request.uri}
			}
		}
		# Strip /derp-status prefix truoc khi gui den node-dedup
		uri strip_prefix /derp-status
		reverse_proxy node-dedup:8090
	}

	# Dashboard quan ly DERP (shadcn-admin) duoi /app: Caddy strip /app -> derp-backend.
	handle_path /app/* {
		reverse_proxy derp-backend:8787
	}

	# Public client API — agent gọi GET /api/client/config và POST /api/metrics/report
	# mà không có /app prefix (serverURL = vpn2.hangocthanh.io.vn, không có /app).
	handle /api/client/* {
		reverse_proxy derp-backend:8787
	}
	handle /api/metrics/report {
		reverse_proxy derp-backend:8787
	}

	# Vao root vpn2.hangocthanh.io.vn -> redirect sang /app/.
	@home path /
	handle @home {
		redir * /app/ 302
	}

	# vpn2 pure-DERP relay (derp-relay container, tach khoi headscale control plane).
	# Phai dat TRUOC catchall headscale de ghi de /derp* va /key.
	handle /derp* {
		reverse_proxy derp-relay:3340
	}
	handle /key {
		reverse_proxy derp-relay:3340
	}

	# Tat ca con lai (/ts2021, /api/v1, /machine, /register, /oidc, ...) -> Headscale.
	# /derp* va /key da duoc xu ly o tren -> KHONG den day nua.
	handle {
		reverse_proxy headscale:8080
	}
}
