# Reverse proxy + auto TLS (Let's Encrypt) cho Headscale.
{
	# Plugin replace-response: cho phep dung directive `replace` (chen nut Thong ke).
	order replace after encode
	# DIAG TAM THOI: bat debug de log chi tiet loi reverse_proxy/forward_auth (502).
	debug
}

vpn2.hangocthanh.io.vn {
	# DIAG TAM THOI: log truy cap JSON ra stdout -> bat duoc status + loi upstream
	# cua tung request that tu trinh duyet (vd 502 tren /stats). Se xoa sau.
	log {
		output stdout
		format json
	}

	# Các endpoint của oauth2-proxy (đăng nhập Google, callback...)
	handle /oauth2/* {
		reverse_proxy oauth2-proxy:4180 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Uri {uri}
		}
	}

	# Web UI /admin → Headplane. Headplane tự lo đăng nhập Google (OIDC) nên
	# KHÔNG cần forward_auth/oauth2-proxy ở đây nữa. Callback của Headplane là
	# /admin/oidc/callback (vẫn nằm trong /admin → headplane).
	handle /admin* {
		# Chen 1 nut noi "Thong ke" vao cuoi trang Headplane (link sang /stats).
		# Accept-Encoding identity de Headplane tra HTML khong nen -> replace khop.
		reverse_proxy headplane:3000 {
			header_up Accept-Encoding identity
		}
		replace `</body>` `<a href="/stats" target="_blank" title="Xem thong ke latency/MAC" style="position:fixed;z-index:99999;right:18px;bottom:18px;background:#2563eb;color:#fff;padding:10px 16px;border-radius:10px;font:600 13px system-ui,Arial,sans-serif;text-decoration:none;box-shadow:0 4px 14px rgba(0,0,0,.45)">&#128202; Th&#7889;ng k&#234;</a></body>`
	}

	# Captive-portal probe cua client (fork dung domain rieng thay tailscale.com)
	# -> tra 204 de client biet "khong co captive portal".
	handle /generate_204 {
		respond 204
	}

	# Trang thong ke (GUI) /stats - gated bang Google SSO (oauth2-proxy). Tro toi
	# collector qua container tailscale sidecar (node-dedup nam trong netns do, bind
	# :8090) tren compose network. CHI GET (xem); POST /metrics/report khong di qua
	# day (chi trong tailnet). Chua dang nhap -> redirect sang Google.
	handle /stats* {
		forward_auth oauth2-proxy:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-Email X-Auth-Request-User
			@unauth status 401
			handle_response @unauth {
				redir * /oauth2/start?rd={http.request.uri}
			}
		}
		reverse_proxy tailscale:8090
	}

	# Còn lại → Headscale control plane / API (xác thực bằng API key/node key)
	handle {
		reverse_proxy headscale:8080
	}
}

# === DIAG TAM THOI (chan doan 502 /stats) — SE XOA sau khi tim ra nguyen nhan ===
# Listener noi bo :8081 KHONG duoc publish ra ngoai (docker-compose khong map port
# nay) -> chi truy cap duoc tu BEN TRONG container caddy / mang docker noi bo, KHONG
# lo ra internet. Dung de test rieng duong reverse_proxy -> collector (bo qua
# forward_auth/oauth2-proxy) voi FULL body, qua dung transport cua Caddy.
:8081 {
	handle /_diag_stats* {
		rewrite * /stats
		reverse_proxy tailscale:8090
	}
	# Mo phong duong DA DANG NHAP: forward_auth goi /ping (luon 200 = "da auth")
	# roi di tiep sang reverse_proxy collector — y het flow that cua /stats sau auth.
	handle /_diag_authed* {
		forward_auth oauth2-proxy:4180 {
			uri /ping
			copy_headers X-Auth-Request-Email X-Auth-Request-User
		}
		rewrite * /stats
		reverse_proxy tailscale:8090
	}
	handle {
		respond "diag-ok" 200
	}
}
